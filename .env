# ============================================================================
# DO NOT EDIT THIS FILE on the server.
# Copy it to .env.local and edit .env.local with your real secrets.
# .env.local is gitignored and will not be committed.
# ============================================================================

###> symfony/framework-bundle ###
APP_ENV=prod
# Generate with: php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=change-me-in-env-local-or-platform-secret

# Optional dedicated encryption key for stored merchant secrets/credentials.
# If omitted, APP_SECRET is used as the encryption source.
# APP_ENCRYPTION_KEY=change-me-too

# The public HTTPS URL where THIS app is deployed.
# Used when registering the Zelty webhook target. MUST be https://
APP_PUBLIC_URL=change-me-to-your-local-or-platform-url

###> ZELTY Webhook Secret ###
ZELTY_WEBHOOK_SECRET=change-me-to-your-zelty-webhook-secret
###< ZELTY Webhook Secret ###

# Optional persistent storage path for webhook secrets + idempotency keys.
# On Railway, set this to a mounted volume path such as /data/app-storage.
# If unset, the app falls back to ./var (fine locally, not persistent on Railway).
# APP_STORAGE_PATH=/data/app-storage
###< symfony/framework-bundle ###

###> TRYB Marketplace ###
MARKETPLACE_API_BASE_URI=https://api.trybloyalty.com/api/v2/marketplace
# Get this from TRYB after creating your app (Settings -> Apps -> Create App)
MARKETPLACE_API_APP_TOKEN=change-me-to-your-tryb-marketplace-api-app-token
###< TRYB Marketplace ###

###> Zelty POS ###
ZELTY_API_BASE_URI=https://api.zelty.fr/2.10
###< Zelty POS ###
