# ============================================================================
# DO NOT EDIT THIS FILE on the server.
# Copy it to .env.local and edit .env.local with your real secrets.
# .env.local is gitignored and will not be committed.
# ============================================================================

###> symfony/framework-bundle ###
APP_ENV=prod
# Generate with: php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=REPLACE_ME_WITH_A_RANDOM_32_CHAR_HEX_STRING

# The public HTTPS URL where THIS app is deployed.
# Used when registering the Zelty webhook target. MUST be https://
APP_PUBLIC_URL=https://your-deployed-domain.com

# Optional persistent storage path for webhook secrets + idempotency keys.
# On Railway, set this to a mounted volume path such as /data/app-storage.
# If unset, the app falls back to ./var (fine locally, not persistent on Railway).
# APP_STORAGE_PATH=/data/app-storage
###< symfony/framework-bundle ###

###> TRYB / Boomerangme Marketplace ###
MARKETPLACE_API_BASE_URI=https://api.digitalwallet.cards/api/v2/marketplace
# Get this from TRYB after creating your app (Settings -> Apps -> Create App)
MARKETPLACE_API_APP_TOKEN=REPLACE_ME_WITH_TRYB_APP_TOKEN
###< TRYB / Boomerangme Marketplace ###

###> Zelty POS ###
ZELTY_API_BASE_URI=https://api.zelty.fr
###< Zelty POS ###
